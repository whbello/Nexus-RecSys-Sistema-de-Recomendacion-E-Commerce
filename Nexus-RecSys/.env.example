# ──────────────────────────────────────────────────────────────────────────────
# nexus-recsys — Variables de entorno (plantilla pública)
#
# Copiar este archivo como .env y completar con los valores reales.
# NUNCA subir el archivo .env con credenciales reales al repositorio.
#
#   cp .env.example .env
#
# ──────────────────────────────────────────────────────────────────────────────


# ── GROQ API KEY ──────────────────────────────────────────────────────────────
# Requerida para activar NEXUS AI (página "Asistente IA" del dashboard).
# Obtené tu clave gratuita en: https://console.groq.com/keys
#
# El dashboard funciona sin esta clave (LLM desactivado, fallback a mensajes
# estáticos). Las demás páginas (recomendaciones, comparativa, métricas) no
# requieren esta variable.
GROQ_API_KEY=your_groq_api_key_here


# ── MODELO LLM ───────────────────────────────────────────────────────────────
# Modelo rápido: respuestas en ~1s (recomendado para demos)
# Opciones: llama-3.1-8b-instant | llama-3.2-3b-preview
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Modelo de calidad: análisis profundo de métricas y justificaciones
# Opciones: llama-3.3-70b-versatile | llama-3.1-70b-versatile
GROQ_QUALITY_MODEL=llama-3.3-70b-versatile


# ── CONFIGURACIÓN DEL DASHBOARD ───────────────────────────────────────────────
# Número máximo de usuarios cargados para la demo en vivo
# Reducir a 500-1000 si el equipo tiene poca RAM disponible
MAX_EVAL_USERS=3000

# Puerto Streamlit (descomentar para cambiar el default 8501)
# STREAMLIT_PORT=8501
